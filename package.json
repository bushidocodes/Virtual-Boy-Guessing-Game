{
  "name": "virtual-boy-guessing-game",
  "version": "1.0.0",
  "description": "A simple guessing game web application using a vector art style inspired by the Nintendo Virtual Boy",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "start": "vite --port 3000",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
